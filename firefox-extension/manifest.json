{
  "manifest_version": 3,
  "name": "Pinakotheke",
  "version": "1.17.1",
  "description": "Least-privilege client for one configured Pinakotheke instance.",
  "icons": {"16": "icon-16.png", "32": "icon-32.png", "48": "icon-48.png", "96": "icon-96.png"},
  "permissions": ["storage", "activeTab", "scripting"],
  "optional_host_permissions": ["https://*/*"],
  "background": {"scripts": ["background.js"]},
  "content_security_policy": {"extension_pages": "script-src 'self'; object-src 'none'"},
  "action": {
    "default_title": "Pinakotheke cache",
    "default_popup": "popup.html",
    "default_icon": {"16": "icon-16.png", "32": "icon-32.png"}
  },
  "options_ui": {"page": "options.html", "open_in_tab": true},
  "browser_specific_settings": {
    "gecko": {
      "id": "x-img@example.invalid",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["browsingActivity", "websiteContent", "websiteActivity"]
      }
    }
  }
}
