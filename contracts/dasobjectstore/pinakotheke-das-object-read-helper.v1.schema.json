{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sagrudd/pinakotheke/contracts/dasobjectstore/pinakotheke-das-object-read-helper.v1.schema.json",
  "title": "Pinakotheke DASObjectStore object read helper configuration v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "endpoint_id", "endpoint_url", "region", "profile", "aws_executable", "stores"],
  "properties": {
    "schema_version": {"const": "pinakotheke.das-object-read-helper.v1"},
    "endpoint_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "endpoint_url": {"type": "string", "minLength": 1, "maxLength": 2048},
    "region": {"type": "string", "minLength": 1, "maxLength": 64},
    "profile": {"type": "string", "minLength": 1, "maxLength": 128},
    "aws_executable": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "stores": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["object_store_id", "bucket"],
        "properties": {
          "object_store_id": {"type": "string", "minLength": 1, "maxLength": 128},
          "bucket": {"type": "string", "minLength": 3, "maxLength": 63}
        }
      }
    },
    "max_object_bytes": {"type": "integer", "minimum": 1, "maximum": 17179869184}
  }
}
