{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sagrudd/pinakotheke/contracts/dasobjectstore/pinakotheke-object-delete-helper.v1.schema.json",
  "title": "Pinakotheke authoritative object delete helper v1",
  "description": "Exact immutable identity exchanged with a host-owned DASObjectStore deletion adapter. No media bytes or credentials are represented.",
  "oneOf": [
    {"$ref": "#/$defs/request"},
    {"$ref": "#/$defs/result"}
  ],
  "$defs": {
    "identifier": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._:-]+$"},
    "checksum": {"type": "string", "pattern": "^sha256:[0-9a-fA-F]{64}$"},
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "endpoint_id", "object_store_id", "object_key", "object_version", "checksum"],
      "properties": {
        "schema_version": {"const": "pinakotheke.object-delete-helper.v1"},
        "endpoint_id": {"$ref": "#/$defs/identifier"},
        "object_store_id": {"$ref": "#/$defs/identifier"},
        "object_key": {"type": "string", "minLength": 1, "maxLength": 512},
        "object_version": {"type": "integer", "minimum": 1},
        "checksum": {"$ref": "#/$defs/checksum"}
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "schema_version"],
      "properties": {
        "outcome": {"enum": ["deleted", "already_absent", "rejected", "unavailable"]},
        "schema_version": {"const": "pinakotheke.object-delete-helper.v1"}
      }
    }
  }
}
